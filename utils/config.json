    },
    "low_density_lipoprotein": {
      "condition": "ldl and ldl>3.3",
      "preference": ["low_cholesterol", "high_fiber", "low_saturated_fat","low_density_lipoprotein"]
    },
    "blood_urea_nitrogen": {
      "condition": "blood_urea_nitrogen>=7.1",
