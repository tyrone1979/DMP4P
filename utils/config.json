    },
    "opioid_misuse": {
      "active_user":"(heroin.isin([4,-1])==False) | (meth.isin([4,-1])==False)| (cocaine.isin([4,-1])==False)",
      "multum_drug_therapeutic_category": "level_one==57 and level_two==58 and (level_three==60 or level_three==191)",
      "opioid_used": "(drunk_days > 90) and ( (used==1 and drug_id in multum_drug_therapeutic_categories ) or (icd_code=='F11.2' or icd_code=='F11.23') )",
      "condition": "user in active_user or user in opioid_used",
      "preference": ["low_sugar", "high_protein", "high_fiber","opioid_misuse"]
    },
    "diabetes": {
      "condition": "glucose >= 7.0 and glycohemoglobin >= 6.5",
      "preference": ["low_sugar", "high_fiber", "diabetes"]
    },
    "anemia":{
      "condition": "red_blood_cell_count<= 4 and (hemoglobin<13.2 if gender ==1 else hemoglobin<11.6)",
      "preference": ["high_iron", "high_vitamin_c", "high_folate_acid","high_vitamin_b12", "anemia"]
    },
    "osteoporosis": {
      "condition": "osteoporosis==1",
